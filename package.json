{
  "name": "ttt-browser-extension",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "addfox dev -b edge --cache",
    "build": "addfox build --no-open",
    "zip": "addfox zip",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.312",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "addfox": "^0.1.1-beta.15",
    "bun-types": "^1.3.11",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4",
    "jsdom": "^27.0.1"
  }
}
