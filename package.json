{
  "name": "ttt-browser-extension",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --localstorage-file=.wxt/localstorage ./node_modules/wxt/bin/wxt.mjs",
    "build": "node --localstorage-file=.wxt/localstorage ./node_modules/wxt/bin/wxt.mjs build",
    "zip": "node --localstorage-file=.wxt/localstorage ./node_modules/wxt/bin/wxt.mjs zip",
    "typecheck": "node --localstorage-file=.wxt/localstorage ./node_modules/wxt/bin/wxt.mjs build && tsc -p tsconfig.json --noEmit",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.312",
    "bun-types": "^1.3.11",
    "typescript": "^5.9.3",
    "wxt": "^0.20.20"
  }
}
