{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "types": ["vitest/globals", "node"],
    "paths": {
      "@": ["."],
      "@/*": ["./*"],
      "~": ["."],
      "~/*": ["./*"],
      "@@": ["."],
      "@@/*": ["./*"],
      "~~": ["."],
      "~~/*": ["./*"]
    }
  },
  "include": ["vitest.config.ts", "src/**/*.test.ts", "src/**/*.spec.ts", "src/test/**/*.ts"]
}
